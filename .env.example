# Grocy backend host (host:port — no scheme)
GROCY_HOST=192.168.1.61:9192
GROCY_API_KEY=your-grocy-api-key-here

# Grocy entity IDs — match your Grocy instance (defaults shown)
VITE_GROCY_DESPENSA_GROUP_ID=6
VITE_GROCY_DEFAULT_LOCATION_ID=2
VITE_GROCY_DEFAULT_QU_ID=2

# OpenRouter — IA no Add Meal (chave só no servidor via proxy /ai)
OPENROUTER_API_KEY=your-openrouter-api-key-here
VITE_OPENROUTER_TEXT_MODEL=deepseek/deepseek-v4-flash
VITE_OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
